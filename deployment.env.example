# ABLE Tracker — Deployment-Specific Configuration
#
# Copy this file to deployment.env and fill in the values from your
# CDK deployment output. deployment.env is .gitignored and will NOT
# be committed to version control.
#
# These values are unique to each deployment and should never be
# hardcoded in source files. After deploying with CDK, you can find
# most of these values in the CloudFormation stack outputs.

# ─── Frontend (CloudFront distribution) ───────────────────────────
# The CloudFront URL where the frontend is served.
# Found in CDK output: AbleTrackerHostingStack.DistributionDomainName
CLOUDFRONT_URL=https://your-distribution-id.cloudfront.net

# The CloudFront distribution ID (used for cache invalidation).
# Found in CDK output: AbleTrackerHostingStack.DistributionId
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXX

# The S3 bucket that hosts the frontend assets.
# Found in CDK output: AbleTrackerHostingStack.BucketName
S3_FRONTEND_BUCKET=your-frontend-bucket-name

# ─── API (API Gateway) ───────────────────────────────────────────
# The API Gateway endpoint URL (no trailing slash).
# Found in CDK output: AbleTrackerApiStack.ApiUrl
API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# ─── Auth (Cognito) ──────────────────────────────────────────────
# The Cognito User Pool ID for authentication.
# Found in CDK output: AbleTrackerAuthStack.UserPoolId
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# The Cognito App Client ID for the frontend.
# Found in CDK output: AbleTrackerAuthStack.UserPoolClientId
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AWS ─────────────────────────────────────────────────────────
# The AWS region where the stack is deployed.
AWS_REGION=us-east-1
