# Test environment defaults for Vitest.
# These values are used when running tests so that config.ts
# can load without throwing. They are NOT real deployment values.
VITE_COGNITO_USER_POOL_ID=us-east-1_TestPool
VITE_COGNITO_CLIENT_ID=test-client-id-000000
VITE_AWS_REGION=us-east-1
VITE_API_URL=https://test-api.example.com
